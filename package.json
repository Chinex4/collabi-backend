{
  "name": "collabi-backend",
  "version": "1.0.0",
  "description": "Production-style backend API for a Student Project Collaboration Platform",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "keep-alive": "node scripts/renderKeepAlive.js",
    "seed": "node src/seeders/seed.js",
    "lint": "eslint .",
    "docs:postman": "node src/docs/generatePostmanCollection.js",
    "test": "node --test --test-concurrency=1",
    "test:chat": "node --test --test-concurrency=1 test/chat.http.test.js test/chat.socket.test.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "socket.io",
    "student-projects"
  ],
  "author": "Codex",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.10.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
