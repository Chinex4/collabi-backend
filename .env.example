PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/student-collab
JWT_SECRET=super-secret-access-token
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=super-secret-refresh-token
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=mailtrap-user
EMAIL_PASS=mailtrap-pass
EMAIL_FROM=Student Collaboration Platform <no-reply@studentcollab.test>
CLIENT_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
MAX_FILE_SIZE_MB=10
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3000/verify-email
